{
  "name": "codeglance",
  "version": "0.1.0",
  "description": "Understand any codebase at a glance",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "codeglance": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "codebase-analysis",
    "repo-analyzer",
    "onboarding",
    "llm",
    "typescript",
    "static-analysis",
    "terminal",
    "productivity"
  ],
  "author": "Mansoor Mamnoon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mansoor-mamnoon/codeglance.git"
  },
  "homepage": "https://github.com/mansoor-mamnoon/codeglance#readme",
  "bugs": {
    "url": "https://github.com/mansoor-mamnoon/codeglance/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ignore": "^5.3.1",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitest/coverage-v8": "^1.5.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
